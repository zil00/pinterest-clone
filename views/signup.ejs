<!DOCTYPE html>
<html>
  <head>
    <title><%= title %></title>
    <link rel="stylesheet" href="/stylesheets/style.css" />
  </head>
  <body>
    <div class="container signup">
      <div class="content">
        <img
          src="https://i.pinimg.com/originals/d3/d1/75/d3d175e560ae133f1ed5cd4ec173751a.png"
          alt="pin logo"
          class="img1"
        />
        <p class="header header--compact">Sign up</p>

        <input type="email" name="email" placeholder="Email" class="detail" />
        <input type="text" name="username" placeholder="Username" class="detail" />
        <input type="text" name="firstName" placeholder="First name" class="detail" />
        <input type="text" name="lastName" placeholder="Last name" class="detail" />

        <button type="button" class="btn int">Sign up</button>

        <footer>
          <p>
            By continuing, you agree to Pinterest's
            <b>Terms of Service, Privacy policy.</b>
          </p>
          <hr />
          <p>Already on Pinterest? <a href="/">Log in</a></p>
        </footer>
      </div>
    </div>
  </body>
</html>
